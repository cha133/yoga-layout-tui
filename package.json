{
  "name": "yoga-layout-tui",
  "version": "0.3.0",
  "description": "Pure TypeScript port of Meta's Yoga flexbox engine — TUI-only subset",
  "license": "MIT",
  "author": "Chacha <cha133@users.noreply.github.com>",
  "keywords": [
    "yoga",
    "flexbox",
    "layout",
    "tui",
    "terminal",
    "ink",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cha133/yoga-layout-tui.git"
  },
  "bugs": {
    "url": "https://github.com/cha133/yoga-layout-tui/issues"
  },
  "homepage": "https://github.com/cha133/yoga-layout-tui#readme",
  "type": "module",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:e2e": "bun test tests/e2e",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:src": "biome check src",
    "format": "biome format --write src tests",
    "format:src": "biome format --write src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@types/bun": "latest",
    "typescript": "^5"
  }
}